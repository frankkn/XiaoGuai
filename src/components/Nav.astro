---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const { current } = Astro.props;
const links = [
  { href: '/', label: '主頁', key: 'home' },
  { href: '/intro', label: '介紹', key: 'intro' },
  { href: '/photos', label: '照片', key: 'photos' },
  { href: '/video', label: '影片', key: 'video' },
  { href: '/contact', label: '小乖Q&A', key: 'contact' },
];
---
<header class="site-header">
  <div class="wrap">
    <a class="brand" href={base + '/'}>
      <img src={base + '/images/logo.png'} alt="小乖趴在藍色毯子上" />
      <b>小乖果實</b>
    </a>
    <nav>
      <ul>
        {links.map((l) => (
          <li>
            {l.key === current
              ? <span class="current">{l.label}</span>
              : <a href={base + l.href}>{l.label}</a>}
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>
