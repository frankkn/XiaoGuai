---
import Base from '../layouts/Base.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const schedule = [
  ['上午', '起床去公園尿尿、吃早餐'],
  ['中午', '睡午覺'],
  ['下午', '邊玩玩具邊看家，偶爾外出辦公'],
  ['晚上', '吃晚餐、睡覺'],
];
---
<Base title="小乖的介紹" description="小乖的基本資料與日程表" current="intro">
  <section class="hero">
    <h1>來認識我吧！</h1>
  </section>

  <article class="card">
    <img src={base + '/images/恐龍.jpg'} alt="小乖" style="border-radius:16px;margin-bottom:20px;" loading="lazy" />
    <p><strong>生日：</strong>民國 100 年的某月某日</p>
    <p><strong>性別：</strong>Female ♀</p>
    <p><strong>特技：</strong>坐下、握手（僅限有食物和心情好時）</p>
  </article>

  <article class="card">
    <table>
      <caption>小乖的一日日程表</caption>
      <tbody>
        {schedule.map(([when, what]) => (
          <tr><th scope="row">{when}</th><td>{what}</td></tr>
        ))}
      </tbody>
    </table>
  </article>
</Base>
