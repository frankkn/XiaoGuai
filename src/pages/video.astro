---
import fs from 'node:fs';
import path from 'node:path';
import Base from '../layouts/Base.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// 特定檔名的說明文字；其餘自動用檔名（去掉「小乖-」前綴）當說明
const captions = {
  'eat.mp4': '吃皮鞋',
  'walk.mp4': '晚上去公園的路上',
};
const fromName = (f) =>
  f.replace(/\.[^.]+$/, '').replace(/^小乖-/, '');

// 自動掃描 public/videos，之後新增影片會自動出現
const dir = path.join(process.cwd(), 'public', 'videos');
const clips = fs
  .readdirSync(dir)
  .filter((f) => /\.(mp4|mov|webm)$/i.test(f))
  .sort()
  .map((f) => ({ src: '/videos/' + f, cap: captions[f] || fromName(f) }));
---
<Base title="小乖的生活影片" description="小乖的生活影片" current="video">
  <section class="hero">
    <h1>生活影片 🎬</h1>
    <p>共 {clips.length} 部</p>
  </section>

  <div class="videos">
    {clips.map((c) => (
      <figure>
        <video controls preload="metadata" src={base + c.src}></video>
        {c.cap && <figcaption>{c.cap}</figcaption>}
      </figure>
    ))}
  </div>
</Base>
